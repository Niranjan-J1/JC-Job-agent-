# ── Database ─────────────────────────────────────────
# Credentials that both  postgres and python app use
POSTGRES_USER=jobagent
POSTGRES_PASSWORD=changeme
POSTGRES_DB=jobagent
DATABASE_URL=postgresql://jobagent:changeme@db:5432/jobagent ## full conection string that sql alchemy reads 

# ── Redis / Celery ────────────────────────────────────
# two sperate redis databases /o and/1 for broker vs results so they dont intefere with one another 
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── AI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-... 

# ── App ───────────────────────────────────────────────
ENV=development 
SECRET_KEY=change-this-in-production
OUTPUT_DIR=/app/output

# ── Pipeline schedule (cron, default: 2 AM daily) ─────
PIPELINE_CRON_HOUR=2
PIPELINE_CRON_MINUTE=0

# ── Scoring thresholds ────────────────────────────────
AUTO_APPLY_THRESHOLD=0.75 ##routes for tiers 
ASSISTED_APPLY_THRESHOLD=0.50

# ── Scraper credentials ───────────────────────────────
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
WATERLOO_WORKS_USERNAME=
WATERLOO_WORKS_PASSWORD=